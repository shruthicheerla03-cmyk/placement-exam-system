rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Users collection - users can read their own data, admins can read all
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if request.auth.uid == userId || isAdmin();
      allow create: if isAuthenticated();
    }
    
    // Exams collection - students can read, only admins can write
    match /exams/{examId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Questions collection - students can read, only admins can write
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Submissions - students can create their own, admins can read all
    match /submissions/{submissionId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // DSA Submissions - students can create their own, admins can read all
    match /dsaSubmissions/{submissionId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Violations - students can create, admins can read all
    match /violations/{violationId} {
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Exam Sessions - students can write their own, admins can read all
    match /examSessions/{sessionId} {
      allow create, update: if isAuthenticated();
      allow read: if isAuthenticated();
      allow delete: if isAdmin();
    }
    
    // Blocked Students - only admins can manage
    match /blockedStudents/{blockId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Admin Actions - only admins can manage
    match /adminActions/{actionId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
